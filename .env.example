# Copy to .env and adjust for local development:
#   cp .env.example .env

# Database
POSTGRES_DB=saasstack
POSTGRES_USER=saas
POSTGRES_PASSWORD=changeme
DB_HOST=db
DB_PORT=5432

# Django
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=True

# Superuser (optional: created by backend entrypoint on first boot)
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=changeme

# JWT — dev uses 7-day access when DEBUG=True unless set:
# SIMPLE_JWT_ACCESS_MINUTES=15
SIMPLE_JWT_REFRESH_DAYS=30

# Redis (optional)
REDIS_HOST=redis
REDIS_PORT=6379
